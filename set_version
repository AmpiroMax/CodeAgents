#!/usr/bin/env python3
"""Bump the CodeAgents version everywhere from a single command.

Usage:
    ./set_version 3 12 2     # → v3.12.2
    ./set_version 3.12.2     # also accepted

Touches:
    - src/codeagents/_version.py   (the only authoritative source)
    - pyproject.toml               (Python build metadata)
    - gui/package.json             (npm package metadata)

Anything else (HTTP /health, GUI status bar, chat metadata stamps) reads
from these files at runtime, so no other edits are needed.
"""
from __future__ import annotations

import json
import re
import sys
from pathlib import Path

REPO = Path(__file__).resolve().parent
TARGETS = {
    "version_py": REPO / "src" / "codeagents" / "_version.py",
    "pyproject": REPO / "pyproject.toml",
    "gui_pkg": REPO / "gui" / "package.json",
}


def parse_args(argv: list[str]) -> str:
    if len(argv) == 1 and re.fullmatch(r"\d+\.\d+\.\d+", argv[0]):
        return argv[0]
    if len(argv) == 3 and all(part.isdigit() for part in argv):
        return ".".join(argv)
    print("usage: ./set_version <major> <minor> <patch>", file=sys.stderr)
    print("       ./set_version 3.12.2", file=sys.stderr)
    sys.exit(2)


def write_version_py(path: Path, version: str) -> None:
    body = (
        '"""Single source of truth for the CodeAgents build version.\n\n'
        "Other places (``src/codeagents/__init__.py``, ``pyproject.toml``,\n"
        "``gui/package.json``) re-export / mirror this value. Update them via\n"
        "``./set_version <major> <minor> <patch>`` — never edit by hand.\n"
        '"""\n'
        f'__version__ = "{version}"\n'
    )
    path.write_text(body, encoding="utf-8")


def write_pyproject(path: Path, version: str) -> None:
    text = path.read_text(encoding="utf-8")
    new, n = re.subn(
        r'(?m)^(version\s*=\s*)"[^"]+"',
        rf'\1"{version}"',
        text,
        count=1,
    )
    if n != 1:
        raise RuntimeError(f"could not find version line in {path}")
    path.write_text(new, encoding="utf-8")


def write_package_json(path: Path, version: str) -> None:
    raw = json.loads(path.read_text(encoding="utf-8"))
    raw["version"] = version
    # Preserve key order + 2-space indent (matches existing file style).
    path.write_text(json.dumps(raw, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


def main(argv: list[str]) -> int:
    version = parse_args(argv)
    write_version_py(TARGETS["version_py"], version)
    write_pyproject(TARGETS["pyproject"], version)
    write_package_json(TARGETS["gui_pkg"], version)
    print(f"version bumped to v{version}")
    for label, path in TARGETS.items():
        print(f"  {label:10s} {path.relative_to(REPO)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
